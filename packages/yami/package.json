{
  "name": "@yuelioi/yami",
  "version": "1.0.37",
  "description": "💫 A lightweight Tailwind CSS utility library for Yuelioi projects.",
  "main": "src/index.css",
  "type": "module",
  "files": [
    "src"
  ],
  "scripts": {
    "llm": "node scripts/generate-llm-guide.js",
    "release": "pnpm version patch && npm publish --access public",
    "build:plugins": "tsup",
    "dev:plugins": "tsup --watch"
  },
  "exports": {
    ".": "./src/index.css",
    "./index.css": "./src/index.css",
    "./plugins/dropdown": {
      "import": "./dist/plugins/dropdown.js",
      "types": "./dist/plugins/dropdown.d.ts"
    },
    "./plugins/modal": {
      "import": "./dist/plugins/modal.js",
      "types": "./dist/plugins/modal.d.ts"
    },
    "./plugins/popover": {
      "import": "./dist/plugins/popover.js",
      "types": "./dist/plugins/popover.d.ts"
    },
    "./plugins/sidebar": {
      "import": "./dist/plugins/sidebar.js",
      "types": "./dist/plugins/sidebar.d.ts"
    },
    "./plugins": {
      "import": "./dist/plugins/index.js",
      "types": "./dist/plugins/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Yuelioi/yami.git",
    "directory": "packages/yami"
  },
  "keywords": [
    "tailwindcss",
    "plugin",
    "css",
    "utilities",
    "yami",
    "yuelioi"
  ],
  "license": "MIT",
  "devDependencies": {
    "tailwindcss": "^4.1.13",
    "tsup": "^8.5.1",
    "tw-animate-css": "^1.4.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "public"
  },
  "packageManager": "pnpm@10.8.1"
}
